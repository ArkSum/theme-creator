    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "source",
                    "keyword.operator",
                    "markup.text"
                ],
                "settings": {
                    "foreground": "#c9c2b5"
                }
            },
            {
                "scope": [
                    "comment",
                    "comment.in_line",
                    "comment.block.documentation",
                    "string.quoted.docstring.multi.python"
                ],
                "settings": {
                    "foreground": "#b99f79"
                }
            },
            {
                "scope": "constant.numeric",
                "settings": {
                    "foreground": "#baddf0"
                }
            },
            {
                "scope": "string",
                "settings": {
                    "foreground": "#6bbd85"
                }
            },
            {
                "scope": [
                    "keyword",
                    "meta.preprocessor",
                    "keyword.control",
                    "storage.type",
                    "keyword.operator.quantifier.regexp"
                ],
                "settings": {
                    "foreground": "#fc3b1b"
                }
            },
            {
                "scope": [
                    "constant.language",
                    "constant.character.python",
                    "storage.type.format.python",
                    "keyword.operator.logical.python",
                    "constant.character.format.placeholder.other.python"
                ],
                "settings": {
                    "foreground": "#ca4212",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": [
                    "entity.name.function",
                    "support.function",
                    "support.function.magic.python"
                ],
                "settings": {
                    "foreground": "#e5e7fc",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": [
                    "variable",
                    "support.type.property-name",
                    "support.variable",
                    "entity.other.attribute"
                ],
                "settings": {
                    "foreground": "#96a2c4"
                }
            },
            {
                "scope": [
                    "variable.parameter"
                ],
                "settings": {
                    "foreground": "#baddf0"
                }
            },
            {
                "scope": [
                    "entity.name.type",
                    "entity.name.namespace",
                    "heading.1.markdown",
                    "heading.2.markdown",
                    "heading.3.markdown",
                    "heading.4.markdown",
                    "heading.5.markdown",
                    "heading.6.markdown"
                ],
                "settings": {
                    "foreground": "#2369b1",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": [
                    "variable.other.enummember",
                    "variable.other.constant",
                    "string.regexp.quoted.single.python",
                    "string.regexp.quoted.double.python",
                    "punctuation.character.set.begin.regexp",
                    "punctuation.character.set.end.regexp",
                    "keyword.operator.negation.regexp",
                    "constant.character.set.regexp",
                    "support.other.parenthesis.regexp"
                ],
                "settings": {
                    "foreground": "#18ade4"
                }
            },
            {
                "scope": "variable.language.python",
                "settings": {
                    "foreground": "#6e7fa8"
                }
            }
        ]
    }
}